# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────

# GitHub Integration (optional — enables live repo data on /projects)
# Set your GitHub username to pull real repos instead of mock data
GITHUB_USERNAME=your-github-username

# GitHub Personal Access Token (optional — increases API rate limits)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxx

# Site URL (used for OG tags, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
